{
  "description": "OKF 노드(docs/knowledge·docs/okf) 작성 시 자동 검증 + index 갱신",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/validate.sh", "timeout": 15 },
          { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/update-index.sh", "timeout": 15 }
        ]
      }
    ]
  }
}
